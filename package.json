{
  "name": "@lbf-fff/skillport",
  "version": "0.1.1",
  "description": "Cross-platform compatibility tester for Agent Skills. Run one SKILL.md on Claude Code, Codex (and more) — see where they diverge.",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "skillport": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "execa": "^9.4.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.1.0",
    "yaml": "^2.6.0"
  },
  "optionalDependencies": {
    "openai": "^4.65.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "agent-skills",
    "skill-md",
    "claude-code",
    "codex",
    "antigravity",
    "cursor",
    "windsurf",
    "testing",
    "compatibility",
    "portability",
    "cli"
  ],
  "license": "MIT",
  "author": "liubaofeng",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suifeng156/skillport.git"
  },
  "homepage": "https://github.com/suifeng156/skillport#readme",
  "bugs": {
    "url": "https://github.com/suifeng156/skillport/issues"
  }
}
